        android:translateX="54"
        android:translateY="54"
        android:rotation="45">
        
        <!-- Main square - Purple -->
        <path
            android:fillColor="#8B5CF6"
            android:pathData="M-28,-28 L28,-28 L28,28 L-28,28 Z"/>
        
        <!-- Inner square - Cyan accent -->
        <path
            android:fillColor="#00D4FF"
            android:pathData="M-20,-20 L20,-20 L20,20 L-20,20 Z"/>
        
        <!-- Center square - Purple -->
        <path
            android:fillColor="#8B5CF6"
            android:pathData="M-12,-12 L12,-12 L12,12 L-12,12 Z"/>
        
        <!-- Small center - Cyan dot -->
        <path
            android:fillColor="#00D4FF"
            android:pathData="M-4,-4 L4,-4 L4,4 L-4,4 Z"/>
    </group>
    
    <!-- Text ORYNTIUM (optional - can be removed if too small) -->
